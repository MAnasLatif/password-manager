{
  "name": "manaspm",
  "description": "MAnasPM (Password Manager) is a secure and user-friendly web application designed to help users manage their passwords and sensitive information efficiently. The application provides features such as password storage, generation, and organization, ensuring that users can keep their credentials safe and easily accessible.",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bun --bun eslint . --max-warnings=0",
    "lint:fix": "bun --bun eslint . --fix",
    "format": "bun --bun prettier . --write",
    "format:check": "bun --bun prettier . --check",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:generate": "bun --bun prisma generate",
    "db:migrate": "bun --bun prisma migrate dev",
    "db:migrate:deploy": "bun --bun prisma migrate deploy",
    "db:migrate:reset": "bun --bun prisma migrate reset",
    "db:push": "bun --bun prisma db push",
    "db:seed": "bun --bun prisma db seed",
    "db:studio": "bun --bun prisma studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "^1.3.14",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}