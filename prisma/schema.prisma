// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum VaultEntryVisibility {
  PRIVATE
  COLLECTION
  SHARED
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  EMAIL
  URL
  SECRET
  IMAGE
  KEY_VALUE
}

enum SharePermission {
  VIEW_METADATA
  REVEAL_PASSWORD
  COPY_PASSWORD
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum CollectionRole {
  OWNER
  MEMBER
}

enum ActivityAction {
  ACCOUNT_CREATED
  ACCOUNT_UPDATED
  ACCOUNT_ARCHIVED
  ACCOUNT_DELETED
  PASSWORD_VIEWED
  PASSWORD_COPIED
  PASSWORD_CHANGED
  ACCOUNT_SHARED
  SHARE_REVOKED
  ACCOUNT_MOVED
  COLLECTION_CREATED
  COLLECTION_UPDATED
  COLLECTION_DELETED
  TEAM_CREATED
  TEAM_UPDATED
  TEAM_DELETED
  MEMBER_ADDED
  MEMBER_REMOVED
}

// ─────────────────────────────────────────────
// Better Auth — Core Tables
// https://www.better-auth.com/docs/concepts/database
// ─────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // App relations
  passkeys              Passkey[]
  vaultSettings         VaultSettings?
  vaultEntries          VaultEntry[]
  collections           Collection[]
  collectionMemberships CollectionMember[]
  ownedTeams            Team[]
  teamMemberships       TeamMember[]
  sharedByMe            VaultEntryShare[]  @relation("SharedBy")
  sharedWithMe          VaultEntryShare[]  @relation("SharedWith")
  passwordChanges       PasswordHistory[]
  activityLogs          ActivityLog[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────
// Better Auth — Passkey Plugin
// https://www.better-auth.com/docs/plugins/passkey
// ─────────────────────────────────────────────

model Passkey {
  id           String   @id
  name         String?
  publicKey    String
  userId       String
  credentialID String
  counter      Int      @default(0)
  deviceType   String
  backedUp     Boolean  @default(false)
  transports   String?
  createdAt    DateTime @default(now())
  aaguid       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

// ─────────────────────────────────────────────
// Vault Security
// ─────────────────────────────────────────────

model VaultSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  pinHash             String?
  vaultTimeoutMinutes Int      @default(15)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vault_settings")
}

// ─────────────────────────────────────────────
// Vault Entry Management (SRS: "Accounts")
// Renamed to VaultEntry to avoid conflict with
// Better Auth's Account table (OAuth providers)
// ─────────────────────────────────────────────

model PlatformPreset {
  id           String  @id @default(cuid())
  name         String  @unique
  icon         String?
  suggestedUrl String?

  vaultEntries VaultEntry[]

  @@map("platform_presets")
}

model VaultEntry {
  id                String               @id @default(cuid())
  userId            String
  title             String
  platformPresetId  String?
  url               String?
  usernameOrEmail   String?
  encryptedPassword String
  notes             String?
  iconKey           String?
  visibility        VaultEntryVisibility @default(PRIVATE)
  collectionId      String?
  archived          Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformPreset  PlatformPreset?         @relation(fields: [platformPresetId], references: [id], onDelete: SetNull)
  collection      Collection?             @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  customFields    VaultEntryCustomField[]
  tags            Tag[]
  shares          VaultEntryShare[]
  teamShares      VaultEntryTeamShare[]
  passwordHistory PasswordHistory[]
  activityLogs    ActivityLog[]

  @@index([userId])
  @@index([collectionId])
  @@index([platformPresetId])
  @@index([title])
  @@index([archived])
  @@map("vault_entries")
}

model VaultEntryCustomField {
  id           String          @id @default(cuid())
  vaultEntryId String
  label        String
  value        String
  fieldType    CustomFieldType @default(TEXT)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  vaultEntry VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)

  @@index([vaultEntryId])
  @@map("vault_entry_custom_fields")
}

model Tag {
  id           String   @id @default(cuid())
  name         String
  vaultEntryId String
  createdAt    DateTime @default(now())

  vaultEntry VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)

  @@unique([vaultEntryId, name])
  @@index([name])
  @@map("tags")
}

// ─────────────────────────────────────────────
// Collections
// ─────────────────────────────────────────────

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaultEntries VaultEntry[]
  members      CollectionMember[]

  @@index([userId])
  @@map("collections")
}

model CollectionMember {
  id           String         @id @default(cuid())
  collectionId String
  userId       String
  role         CollectionRole @default(MEMBER)
  createdAt    DateTime       @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId])
  @@map("collection_members")
}

// ─────────────────────────────────────────────
// Teams
// ─────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner      User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members    TeamMember[]
  teamShares VaultEntryTeamShare[]

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

// ─────────────────────────────────────────────
// Sharing
// ─────────────────────────────────────────────

model VaultEntryShare {
  id           String            @id @default(cuid())
  vaultEntryId String
  sharedById   String
  sharedWithId String
  permissions  SharePermission[]
  createdAt    DateTime          @default(now())
  revokedAt    DateTime?

  vaultEntry VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)
  sharedBy   User       @relation("SharedBy", fields: [sharedById], references: [id], onDelete: Cascade)
  sharedWith User       @relation("SharedWith", fields: [sharedWithId], references: [id], onDelete: Cascade)

  @@unique([vaultEntryId, sharedWithId])
  @@index([sharedById])
  @@index([sharedWithId])
  @@map("vault_entry_shares")
}

model VaultEntryTeamShare {
  id           String            @id @default(cuid())
  vaultEntryId String
  teamId       String
  permissions  SharePermission[]
  createdAt    DateTime          @default(now())
  revokedAt    DateTime?

  vaultEntry VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([vaultEntryId, teamId])
  @@map("vault_entry_team_shares")
}

// ─────────────────────────────────────────────
// Audit & History
// ─────────────────────────────────────────────

model PasswordHistory {
  id                String   @id @default(cuid())
  vaultEntryId      String
  encryptedPassword String
  version           Int
  changedById       String
  changedAt         DateTime @default(now())

  vaultEntry VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)
  changedBy  User       @relation(fields: [changedById], references: [id], onDelete: Cascade)

  @@index([vaultEntryId])
  @@index([changedAt])
  @@map("password_history")
}

model ActivityLog {
  id             String         @id @default(cuid())
  userId         String
  action         ActivityAction
  targetEntityId String?
  vaultEntryId   String?
  metadata       Json?
  createdAt      DateTime       @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaultEntry VaultEntry? @relation(fields: [vaultEntryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([vaultEntryId])
  @@map("activity_logs")
}
